{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for MicLayer. Locked down — no FS, network, or shell APIs by default. Dialog/opener/global-shortcut/autostart plugins are allowed.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:event:default",
    "core:app:default",
    "core:tray:default",
    "core:menu:default",
    "window-state:default",
    "dialog:default",
    "opener:default",
    "global-shortcut:default",
    "autostart:default"
  ]
}
