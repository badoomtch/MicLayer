{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MicLayer",
  "version": "0.0.0",
  "identifier": "app.miclayer.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MicLayer",
        "width": 1100,
        "height": 720,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: http://asset.localhost; media-src 'self' asset: http://asset.localhost blob:; style-src 'self' 'unsafe-inline'; script-src 'self'",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/recordings/*", "$APPDATA/recordings/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "en-US"
      }
    },
    "copyright": "MicLayer contributors",
    "license": "MIT",
    "shortDescription": "Microphone tuning for Windows.",
    "longDescription": "MicLayer is a free, open-source mic tuning app for Windows. Mic in -> tuning chain -> branded virtual microphone."
  }
}
