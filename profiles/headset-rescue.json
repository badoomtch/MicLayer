{
  "schemaVersion": 1,
  "id": "11111111-0000-4000-8000-000000000008",
  "name": "Headset Rescue",
  "author": "MicLayer",
  "kind": "builtin",
  "notes": "For gaming headsets and budget boom mics. Cuts the typical thin nasal honk around 700-900 Hz, restores a little low-end body and high-end air, tames the harsh upper-mid bite. Apply, then re-record a test clip to verify.",
  "createdAt": "2026-05-22T00:00:00Z",
  "updatedAt": "2026-05-22T00:00:00Z",
  "modules": {
    "inputGain":        { "enabled": true,  "params": { "gainDb": 3 } },
    "highPass":         { "enabled": true,  "params": { "mode": "medium", "cutoffHz": 90, "order": 2 } },
    "noiseSuppression": { "enabled": true,  "params": { "amount": 0.6, "voiceFloorDb": -45 } },
    "gate":             { "enabled": true,  "params": { "thresholdDb": -48, "rangeDb": -30, "attackMs": 4, "holdMs": 150, "releaseMs": 250, "hysteresisDb": 3 } },
    "eq": {
      "enabled": true,
      "params": {
        "bands": [
          { "type": "low_shelf",  "frequencyHz": 180,   "gainDb": 3,    "q": 0.7, "enabled": true },
          { "type": "peak",       "frequencyHz": 800,   "gainDb": -4,   "q": 1.5, "enabled": true },
          { "type": "peak",       "frequencyHz": 2500,  "gainDb": -2,   "q": 1.2, "enabled": true },
          { "type": "peak",       "frequencyHz": 5000,  "gainDb": 1.5,  "q": 1.2, "enabled": true },
          { "type": "high_shelf", "frequencyHz": 10000, "gainDb": 3,    "q": 0.7, "enabled": true }
        ]
      }
    },
    "compressor":       { "enabled": true,  "params": { "thresholdDb": -22, "ratio": 3, "attackMs": 12, "releaseMs": 150, "kneeDb": 6, "makeupDb": 0, "autoMakeup": true, "detectorMs": 10 } },
    "deEsser":          { "enabled": true,  "params": { "targetHz": 6500, "thresholdDb": -26, "amountDb": 6, "q": 1.5 } },
    "limiter":          { "enabled": true,  "params": { "ceilingDb": -1, "releaseMs": 50, "lookaheadMs": 2 } },
    "outputGain":       { "enabled": true,  "params": { "gainDb": 0 } }
  }
}
