{
  "schemaVersion": 1,
  "id": "11111111-0000-4000-8000-000000000004",
  "name": "Voiceover",
  "author": "MicLayer",
  "kind": "builtin",
  "notes": "Tight, polished voice for narration / video voiceover. Stronger compression for consistency, de-esser engaged, gate set to keep room out between phrases.",
  "createdAt": "2026-05-22T00:00:00Z",
  "updatedAt": "2026-05-22T00:00:00Z",
  "modules": {
    "inputGain":        { "enabled": true,  "params": { "gainDb": 0 } },
    "highPass":         { "enabled": true,  "params": { "mode": "medium", "cutoffHz": 90, "order": 2 } },
    "noiseSuppression": { "enabled": true,  "params": { "amount": 0.5, "voiceFloorDb": -45 } },
    "gate":             { "enabled": true,  "params": { "thresholdDb": -48, "rangeDb": -30, "attackMs": 3, "holdMs": 180, "releaseMs": 280, "hysteresisDb": 3 } },
    "eq": {
      "enabled": true,
      "params": {
        "bands": [
          { "type": "low_shelf",  "frequencyHz": 200,   "gainDb": 1,   "q": 0.7, "enabled": true },
          { "type": "peak",       "frequencyHz": 300,   "gainDb": -2,  "q": 1.0, "enabled": true },
          { "type": "peak",       "frequencyHz": 3200,  "gainDb": 2.5, "q": 1.0, "enabled": true },
          { "type": "peak",       "frequencyHz": 5500,  "gainDb": 1.5, "q": 1.2, "enabled": true },
          { "type": "high_shelf", "frequencyHz": 12000, "gainDb": 2,   "q": 0.7, "enabled": true }
        ]
      }
    },
    "compressor":       { "enabled": true,  "params": { "thresholdDb": -24, "ratio": 4, "attackMs": 8, "releaseMs": 130, "kneeDb": 4, "makeupDb": 0, "autoMakeup": true, "detectorMs": 8 } },
    "deEsser":          { "enabled": true,  "params": { "targetHz": 7000, "thresholdDb": -28, "amountDb": 6, "q": 1.5 } },
    "limiter":          { "enabled": true,  "params": { "ceilingDb": -1, "releaseMs": 40, "lookaheadMs": 2 } },
    "outputGain":       { "enabled": true,  "params": { "gainDb": 0 } }
  }
}
